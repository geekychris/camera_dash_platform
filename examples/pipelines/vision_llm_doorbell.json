{
  "id": "vision_llm_doorbell",
  "name": "Doorbell describer (Claude)",
  "nodes": [
    { "id": "src", "type": "source.camera", "config": { "camera_id": "REPLACE_ME" } },
    { "id": "yolo", "type": "detector.yolo",
      "config": { "classes": ["person"], "conf": 0.4,
                   "device": "${profile.default_device}" } },
    { "id": "match", "type": "condition.metadata_match",
      "config": { "expression": "d.label == 'person'" } },
    { "id": "cool", "type": "condition.cooldown",
      "config": { "cooldown_s": 60, "scope": "per_camera" } },
    { "id": "describe", "type": "detector.vision_llm",
      "config": {
        "model": "claude-haiku-4-5",
        "prompt": "Someone is at the front door. In one sentence, describe who they appear to be (e.g. delivery driver, neighbor, stranger) and what they're carrying.",
        "trigger_only": true, "min_interval_s": 30, "max_tokens": 120
      } },
    { "id": "tg", "type": "sink.telegram",
      "config": { "template": "🔔 *{camera_id}* — {summary}" } },
    { "id": "rec", "type": "sink.recorder",
      "config": { "pre_roll_s": 5, "post_roll_s": 20 } }
  ],
  "edges": [
    { "from": "src.frame", "to": "yolo.frame" },
    { "from": "yolo.detections", "to": "match.detections" },
    { "from": "match.match", "to": "cool.payload" },
    { "from": "cool.match", "to": "describe.trigger" },
    { "from": "src.frame", "to": "describe.frame" },
    { "from": "describe.event", "to": "tg.payload" },
    { "from": "cool.match", "to": "rec.trigger" }
  ]
}
