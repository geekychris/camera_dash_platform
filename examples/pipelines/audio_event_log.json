{
  "id": "audio_event_log",
  "name": "Audio event log (YAMNet)",
  "nodes": [
    { "id": "mic", "type": "source.audio",
      "config": { "camera_id": "mic_default", "device": "default", "sample_rate": 16000 } },
    { "id": "yamnet", "type": "detector.audio_class",
      "config": {
        "min_score": 0.35,
        "top_k": 3,
        "classes": ["Speech", "Dog", "Glass", "Smoke", "Siren", "Vehicle", "Door"]
      } },
    { "id": "cool", "type": "condition.cooldown",
      "config": { "cooldown_s": 5, "scope": "per_camera_kind" } },
    { "id": "log", "type": "sink.sqlite",
      "config": { "kind": "audio_event" } }
  ],
  "edges": [
    { "from": "mic.audio", "to": "yamnet.audio" },
    { "from": "yamnet.detections", "to": "cool.payload" },
    { "from": "cool.match", "to": "log.payload" }
  ]
}
