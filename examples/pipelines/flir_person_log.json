{
  "id": "flir_person_log",
  "name": "FLIR person detection -> annotated stream + console (every 5s)",
  "nodes": [
    {
      "id": "src",
      "type": "source.camera",
      "config": {
        "camera_id": "flir"
      },
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "yolo",
      "type": "detector.yolo",
      "config": {
        "model": "yolov8n.pt",
        "device": "mps",
        "classes": [
          "person"
        ],
        "conf": 0.15
      },
      "position": {
        "x": 240,
        "y": 0
      }
    },
    {
      "id": "annot",
      "type": "transform.annotate",
      "config": {
        "color": [
          0,
          255,
          0
        ],
        "thickness": 2,
        "show_score": true
      },
      "position": {
        "x": 480,
        "y": 0
      }
    },
    {
      "id": "stream",
      "type": "broadcast.stream",
      "config": {
        "label": "FLIR + person boxes",
        "fps": 9
      },
      "position": {
        "x": 720,
        "y": 0
      }
    },
    {
      "id": "throttle",
      "type": "transform.throttle",
      "config": {
        "interval_s": 5.0
      },
      "position": {
        "x": 480,
        "y": 160
      }
    },
    {
      "id": "log",
      "type": "sink.console",
      "config": {
        "level": "info",
        "format": "compact",
        "prefix": "[flir_person] "
      },
      "position": {
        "x": 720,
        "y": 160
      }
    }
  ],
  "edges": [
    {
      "from": "src.frame",
      "to": "yolo.frame"
    },
    {
      "from": "src.frame",
      "to": "annot.frame"
    },
    {
      "from": "yolo.detections",
      "to": "annot.detections"
    },
    {
      "from": "annot.frame",
      "to": "stream.frame"
    },
    {
      "from": "yolo.detections",
      "to": "throttle.payload"
    },
    {
      "from": "throttle.payload",
      "to": "log.payload"
    }
  ]
}
